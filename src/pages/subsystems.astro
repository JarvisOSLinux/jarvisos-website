---
import BaseLayout from "../layouts/BaseLayout.astro";
import SubsystemCard from "../components/SubsystemCard.astro";

const subsystems = [
  {
    name: "Project-JARVIS",
    repo: "Project-JARVIS",
    description:
      "The AI assistant system — Python daemon, LLM orchestration via Ollama, Textual TUI, voice I/O (Vosk + Piper), session persistence, and the security confirmation gate. This is the brain.",
    tags: ["python", "ollama", "tui", "daemon"],
  },
  {
    name: "dispatch",
    repo: "dispatch",
    description:
      "Signal-driven parallel task orchestrator. One LLM dispatches concurrent tool calls, then goes idle. dispatch runs them in parallel and only wakes the LLM on a signal. One brain, many hands.",
    tags: ["rust", "tokio", "mcp", "signals"],
  },
  {
    name: "dmcp",
    repo: "dmcp",
    description:
      "MCP server lifecycle manager — discover, install, configure, run, and invoke tools. Dual scope (user and system). Also runs as an MCP server itself, exposing management as callable tools.",
    tags: ["rust", "mcp", "dual-scope"],
  },
  {
    name: "contextor",
    repo: "contextor",
    description:
      "Persistent memory backend. Vector similarity search over conversation history, rolling session summaries, and retention-based pruning to keep the LLM's working context bounded and relevant.",
    tags: ["rust", "sqlite", "vectors"],
  },
  {
    name: "mcp-registry",
    repo: "mcp-registry",
    description:
      "Community-vetted MCP server catalog. JSON registry with SHA-256 integrity hashes and embedding vectors for semantic search. The app store for MCP servers.",
    tags: ["registry", "json", "embeddings"],
  },
  {
    name: "jarvisos",
    repo: "jarvisos",
    description:
      "The AI-native Linux distribution. Seven-script modular build pipeline that transforms a base Arch Linux ISO into a bootable AI-native OS with KDE Plasma 6 on Wayland.",
    tags: ["arch-linux", "build-pipeline", "iso"],
  },
  {
    name: "jarvisos-app",
    repo: "jarvisos-app",
    description:
      "Desktop GUI widget. ChatGPT-style chat interface built with Rust + CXX-Qt 0.7 + Qt6/QML. Connects to the JARVIS daemon over a bidirectional Unix socket.",
    tags: ["rust", "qt6", "qml", "gui"],
  },
  {
    name: "linux-jarvisos",
    repo: "linux-jarvisos",
    description:
      "Custom kernel with JARVIS character device drivers. /dev/jarvis misc device, sysmon (CPU/memory/thermal), policy engine (4-tier action gate), API key storage via Linux keyring.",
    tags: ["c", "kernel", "drivers"],
  },
];
---

<BaseLayout
  title="Subsystems & Architecture"
  description="JARVIS OS subsystem breakdown — dispatch (Rust signal orchestrator), dmcp (MCP server manager), contextor (vector memory store), Project-JARVIS AI daemon, custom linux-jarvisos kernel, and jarvisos-app Qt6 GUI."
>
  <section class="section">
    <div class="container">
      <span class="section-label">Architecture</span>
      <h1 class="section-title">Subsystems</h1>
      <p class="sub-intro">
        The JARVIS ecosystem is built as a set of modular, independently maintained
        subsystems. Each component lives in its own repository under the
        <a href="https://github.com/JarvisOSLinux" target="_blank" rel="noopener noreferrer">
          JarvisOSLinux GitHub organization</a>.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <span class="section-label">System diagram</span>
      <div class="diagram">
        <!-- Row 1: User → Project-JARVIS → LLM -->
        <div class="diagram-row">
          <div class="diagram-node node-muted">User</div>
          <div class="diagram-arrow arrow-anim" style="--arrow-delay: 0.2s;">&#9654;</div>
          <div class="diagram-node node-primary">Project-JARVIS</div>
          <div class="diagram-arrow arrow-anim" style="--arrow-delay: 0.4s;">&#9654;</div>
          <div class="diagram-node node-accent">LLM (Ollama)</div>
        </div>

        <!-- Connector down -->
        <div class="diagram-connector">
          <div class="connector-line line-anim" style="--line-delay: 0.6s;"></div>
        </div>

        <!-- Row 2: dispatch → dmcp → MCP Servers -->
        <div class="diagram-row">
          <div class="diagram-node node-primary">dispatch</div>
          <div class="diagram-arrow arrow-anim" style="--arrow-delay: 0.8s;">&#9654;</div>
          <div class="diagram-node node-primary">dmcp</div>
          <div class="diagram-arrow arrow-anim" style="--arrow-delay: 1.0s;">&#9654;</div>
          <div class="diagram-node node-accent">MCP Servers</div>
        </div>

        <!-- Connector down -->
        <div class="diagram-connector">
          <div class="connector-line line-anim" style="--line-delay: 1.2s;"></div>
        </div>

        <!-- Row 3: Supporting subsystems -->
        <div class="diagram-row row-support">
          <div class="diagram-node node-secondary">contextor</div>
          <div class="diagram-node node-secondary">mcp-registry</div>
          <div class="diagram-node node-secondary">jarvisos-app</div>
        </div>

        <!-- Connector down -->
        <div class="diagram-connector">
          <div class="connector-line line-anim" style="--line-delay: 1.4s;"></div>
        </div>

        <!-- Row 4: OS layer -->
        <div class="diagram-row">
          <div class="diagram-node node-kernel">linux-jarvisos</div>
          <div class="diagram-arrow arrow-anim" style="--arrow-delay: 1.6s;">&#9654;</div>
          <div class="diagram-node node-kernel">jarvisos</div>
          <div class="diagram-arrow arrow-anim" style="--arrow-delay: 1.8s;">&#9654;</div>
          <div class="diagram-node node-muted">Bootable ISO</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="grid-2">
        {subsystems.map((s) => <SubsystemCard {...s} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="section-label">GitHub Organization</span>
      <h2 class="section-title">Repository structure</h2>
      <div class="card">
        <pre class="mono repo-tree"><code>github.com/JarvisOSLinux/
├── Project-JARVIS        ← AI assistant system (Python daemon + LLM orchestration)
├── dispatch              ← Rust signal-driven task orchestrator
├── dmcp                  ← Rust MCP server lifecycle manager
├── contextor             ← Rust vector-based memory store
├── mcp-registry          ← JSON registry of installable MCP servers
├── jarvisos              ← AI-native Linux distro (Arch base + build pipeline)
├── jarvisos-app          ← Desktop GUI (Rust + Qt6/QML)
├── linux-jarvisos        ← Custom kernel with /dev/jarvis drivers
└── jarvisos-website      ← this website</code></pre>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sub-intro {
    font-size: 1.05rem;
    max-width: 640px;
  }

  .repo-tree {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* --- Animated diagram --- */
  .diagram {
    padding: var(--space-2xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    overflow-x: auto;
  }

  .diagram-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .row-support {
    gap: var(--space-xl);
  }

  .diagram-node {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.6em 1.2em;
    border-radius: 4px;
    border: 1px solid;
    text-align: center;
    white-space: nowrap;
    opacity: 0;
    animation: node-in 0.4s ease-out forwards;
    animation-delay: var(--arrow-delay, 0s);
  }

  .node-primary {
    color: var(--cyan);
    border-color: var(--cyan);
    background: #00c8ff0a;
    box-shadow: 0 0 12px #00c8ff15;
    --arrow-delay: 0.3s;
  }

  .node-accent {
    color: var(--gold);
    border-color: var(--gold);
    background: #f0a5000a;
    --arrow-delay: 0.5s;
  }

  .node-secondary {
    color: var(--green);
    border-color: #00e67644;
    background: #00e6760a;
    --arrow-delay: 1.3s;
  }

  .node-kernel {
    color: var(--red);
    border-color: #ff3b5c44;
    background: #ff3b5c0a;
    --arrow-delay: 1.5s;
  }

  .node-muted {
    color: var(--text-secondary);
    border-color: var(--border);
    background: transparent;
    --arrow-delay: 0.1s;
  }

  .diagram-arrow {
    color: var(--text-muted);
    font-size: 0.7rem;
    opacity: 0;
    animation: arrow-in 0.3s ease-out forwards;
    animation-delay: var(--arrow-delay, 0s);
  }

  .diagram-connector {
    display: flex;
    justify-content: center;
    height: 28px;
  }

  .connector-line {
    width: 1px;
    height: 0;
    background: var(--border);
    animation: line-grow 0.3s ease-out forwards;
    animation-delay: var(--line-delay, 0s);
  }

  @keyframes node-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes arrow-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes line-grow {
    from { height: 0; }
    to { height: 100%; }
  }

  @media (max-width: 768px) {
    .diagram-row {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .diagram-arrow {
      transform: rotate(90deg);
    }

    .row-support {
      gap: var(--space-sm);
    }
  }
</style>
