---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Choice A — Freedom"
  description="You chose AI working with you. A future where technology serves humanity."
>
  <div class="reveal-overlay" aria-hidden="true">
    <p class="reveal-tagline">You are the one <span class="text-green">in control</span></p>
  </div>

  <section class="choice-hero anim-fade-in" style="--delay: 2.6s;">
    <div class="container">
      <span class="choice-tag">CHOICE A</span>
      <h1 class="choice-heading">AI Working <span class="text-green">With</span> You</h1>
      <p class="choice-subtitle">
        A future where artificial intelligence is a tool — not a master.
        Where technology amplifies human agency rather than replacing it.
      </p>
    </div>
  </section>

  <section class="messages-section">
    <div class="container">
      <div class="anim-fade-in" style="--delay: 3.0s;">
        <span class="section-label">What This Future Looks Like</span>
        <h2 class="section-title text-green">The Open Path</h2>
      </div>

      <div class="message-grid">
        <div class="message-card card-green anim-fade-in" style="--delay: 3.3s;">
          <span class="msg-icon">&#9670;</span>
          <h3>Local &amp; Transparent AI</h3>
          <p>
            Your AI runs on your hardware. No data leaves your machine. No corporation
            harvests your conversations, habits, or decisions. You own your compute,
            your models, and your outputs.
          </p>
        </div>

        <div class="message-card card-green anim-fade-in" style="--delay: 3.5s;">
          <span class="msg-icon">&#9670;</span>
          <h3>User-Controlled Permissions</h3>
          <p>
            AI asks before it acts. Every system access is explicit, logged, and
            revocable. The agent serves your intent — it does not infer authority
            you never granted.
          </p>
        </div>

        <div class="message-card card-green anim-fade-in" style="--delay: 3.7s;">
          <span class="msg-icon">&#9670;</span>
          <h3>Open Research &amp; Accountability</h3>
          <p>
            Security threats are studied in the open — like the threat taxonomy
            published in our research. Vulnerabilities are disclosed, not hidden.
            The community audits what you run.
          </p>
        </div>

        <div class="message-card card-green anim-fade-in" style="--delay: 3.9s;">
          <span class="msg-icon">&#9670;</span>
          <h3>AI Amplifies, Not Replaces</h3>
          <p>
            The system augments your decisions. It surfaces information, executes tasks
            you specify, and stops when you say stop. The human remains the locus of
            judgment and intent.
          </p>
        </div>
      </div>

      <div class="choice-verdict verdict-green anim-fade-in" style="--delay: 4.1s;">
        <span class="tag tag-novel">You Chose This</span>
        <blockquote>
          "Freedom is not the absence of AI — it is AI that remains answerable to the
          people who use it."
        </blockquote>
        <p class="mono text-muted" style="margin-top: var(--space-md); font-size: 0.8rem;">
          This is the research mission behind JARVIS OS. An open platform to study,
          expose, and counteract the threats that emerge when AI gains OS-level privilege
          — so the open path stays open.
        </p>
        <a href="/research" class="btn btn-green" style="margin-top: var(--space-xl);">
          Read the Research →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Reveal overlay --- */
  .reveal-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: overlay-fade 1s ease-out 2.2s forwards;
    pointer-events: none;
  }

  .reveal-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    max-width: 600px;
    padding: 0 var(--space-lg);
    opacity: 0;
    animation:
      tagline-in 0.8s ease-out 0.5s forwards,
      tagline-drift 0.8s ease-in 1.8s forwards;
  }

  @keyframes tagline-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes tagline-drift {
    to {
      opacity: 0;
      transform: translateY(-30px);
    }
  }

  @keyframes overlay-fade {
    to {
      opacity: 0;
      visibility: hidden;
    }
  }

  /* --- Staggered fade-in for page content --- */
  .anim-fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: content-in 0.6s ease-out forwards;
    animation-delay: var(--delay, 2.6s);
  }

  @keyframes content-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* --- Hero --- */
  .choice-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    text-align: center;
  }

  .choice-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--green);
    border: 1px solid var(--green);
    padding: 0.3em 0.8em;
    border-radius: 3px;
    display: inline-block;
    margin-bottom: var(--space-lg);
    background: #00e67615;
    animation: tag-pulse 3s ease-in-out infinite;
    animation-delay: 5s;
  }

  @keyframes tag-pulse {
    0%, 100% { box-shadow: 0 0 0 transparent; }
    50% { box-shadow: 0 0 20px #00e67644; }
  }

  .choice-heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-bottom: var(--space-lg);
  }

  .choice-subtitle {
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-secondary);
  }

  .text-green { color: var(--green); }

  /* --- Content --- */
  .messages-section {
    padding: var(--space-3xl) 0 var(--space-4xl);
  }

  .message-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-3xl);
  }

  .message-card {
    background: var(--bg-card);
    border-radius: 6px;
    padding: var(--space-xl);
    border: 1px solid;
    position: relative;
    transition: all var(--transition-base);
  }

  .card-green {
    border-color: #00e67630;
  }

  .card-green:hover {
    border-color: #00e67666;
    box-shadow: 0 0 25px #00e67618;
    background: var(--bg-card-hover);
  }

  .msg-icon {
    color: var(--green);
    font-size: 0.75rem;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .message-card h3 {
    color: var(--green);
    margin-bottom: var(--space-sm);
    font-size: 1rem;
  }

  .message-card p {
    font-size: 0.9rem;
    max-width: 100%;
  }

  /* --- Verdict --- */
  .choice-verdict {
    padding: var(--space-2xl);
    border-radius: 6px;
    border-left: 3px solid var(--green);
    background: var(--bg-card);
  }

  .verdict-green {
    box-shadow: 0 0 30px #00e67615;
  }

  .choice-verdict blockquote {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--text-primary);
    line-height: 1.5;
    max-width: 640px;
    margin-top: var(--space-md);
  }

  .btn-green {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.75rem 1.5rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid var(--green);
    border-radius: 4px;
    cursor: pointer;
    transition: all var(--transition-base);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: transparent;
    color: var(--green);
    text-decoration: none;
  }

  .btn-green:hover {
    background: var(--green);
    color: var(--bg-primary);
    box-shadow: 0 0 20px #00e67644;
  }

  @media (max-width: 768px) {
    .message-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
