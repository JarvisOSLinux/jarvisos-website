---
import BaseLayout from "../layouts/BaseLayout.astro";

const softwareSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "JARVIS OS",
  operatingSystem: "Linux",
  applicationCategory: "OperatingSystem",
  description:
    "An AI-native operating system built on Arch Linux that gives a large language model full OS privileges to empirically study LLM security threats including prompt injection, context window saturation, and MCP privilege escalation.",
  url: "https://jarvisoslinux.org",
  downloadUrl: "https://jarvisoslinux.org/download",
  softwareVersion: "latest",
  license: "https://opensource.org/licenses/MIT",
  author: {
    "@type": "Organization",
    name: "JarvisOSLinux",
    url: "https://github.com/JarvisOSLinux",
  },
  keywords:
    "AI-native OS, LLM security, Model Context Protocol, prompt injection, Arch Linux, Ollama, MCP security threats",
});

const researchSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ResearchProject",
  name: "JARVIS OS — LLM-OS Security Research",
  description:
    "Empirical study of security threats that emerge when LLMs gain OS-level privileges. Produces the first threat taxonomy for AI-native operating systems.",
  url: "https://jarvisoslinux.org/research",
  funder: {
    "@type": "CollegeOrUniversity",
    name: "Washington State University Everett",
  },
  member: [
    { "@type": "Person", name: "Yakup Atahanov" },
    { "@type": "Person", name: "Toufic Majdaleni" },
  ],
});
---

<BaseLayout
  fullTitle="JARVIS OS — AI-Native Operating System & LLM Security Research Platform"
  description="An Arch Linux research OS that gives an LLM full system privileges to study prompt injection, context saturation, MCP security threats, and privilege escalation. Built at WSU Everett."
>
  <script slot="head" type="application/ld+json" set:html={softwareSchema} />
  <script slot="head" type="application/ld+json" set:html={researchSchema} />
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <img
          src="/assets/jarvisos_cyan_logo_text.jpg"
          alt="JARVIS OS — AI-Native Operating System"
          class="hero-logo"
        />
        <span class="section-label">Research Platform</span>
        <h1>
          An AI-native operating system<br />
          for studying <span class="text-cyan">LLM security threats</span>
        </h1>
        <p class="hero-sub">
          JARVIS OS is an Arch Linux-based research platform that gives a large language model
          full operating system privileges — then studies what can go wrong. Built at
          <strong>WSU Everett</strong> to produce the first empirical threat taxonomy for
          LLM-OS integration.
        </p>
        <div class="hero-actions">
          <a href="/download" class="btn btn-primary">Download ISO</a>
          <a href="/research" class="btn btn-outline">Read the Research</a>
        </div>
        <div class="hero-meta mono">
          <span>Arch Linux + KDE Plasma 6</span>
          <span class="text-muted">&bull;</span>
          <span>Ollama (local LLM)</span>
          <span class="text-muted">&bull;</span>
          <span>MCP Orchestration</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Finding -->
  <section class="section">
    <div class="container">
      <div class="finding-banner glow-border">
        <span class="tag tag-critical">Critical Threat</span>
        <h2>Bloated Context</h2>
        <p>
          Context window saturation silently drops security constraints mid-session.
          The AI doesn't disobey your rules. It forgets them. This is the first identification
          of context saturation as a <strong>discrete security threat</strong> rather than a
          reliability problem.
        </p>
        <a href="/research#bloated-context" class="btn btn-outline" style="margin-top: var(--space-lg);">
          Learn more &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Features overview — asymmetric layout -->
  <section class="section">
    <div class="container">
      <span class="section-label">Architecture</span>
      <h2 class="section-title">How JARVIS OS works</h2>
      <div class="features-grid">
        <div class="card features-card--lead">
          <h3>Local LLM Inference</h3>
          <p>
            Powered by Ollama — all inference runs on-device with zero cloud dependencies.
            Full privacy, full control. No API keys, no rate limits, no telemetry.
          </p>
        </div>
        <div class="card">
          <h3>dispatch + dmcp</h3>
          <p>
            Signal-driven task orchestrator paired with an MCP server lifecycle manager.
            One brain dispatches concurrent tool calls; many hands execute them in parallel.
          </p>
        </div>
        <div class="card">
          <h3>Modular Build System</h3>
          <p>
            Seven scripts transform a base Arch ISO into a bootable AI-native OS. Each stage
            is isolated, auditable, and reproducible.
          </p>
        </div>
        <div class="card">
          <h3>KDE Plasma 6 / Wayland</h3>
          <p>
            Modern desktop environment running on the Wayland display protocol — a full
            graphical workstation, not just a CLI tool.
          </p>
        </div>
        <div class="card">
          <h3>TUI Installer</h3>
          <p>
            Dialog-based installer for permanent deployment to hardware. Auto-installs
            dependencies, supports auto and manual partitioning.
          </p>
        </div>
        <div class="card features-card--wide">
          <h3>Security Research Platform</h3>
          <p>
            Purpose-built to expose and document the real security threats that emerge when
            LLMs gain OS-level control. Research-first, product-second.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Threat overview -->
  <section class="section">
    <div class="container">
      <span class="section-label">Research</span>
      <h2 class="section-title">Threat Taxonomy</h2>
      <p style="margin-bottom: var(--space-2xl);">
        Empirically identified through building and operating an AI-native OS.
        Three privilege escalation stages studied: user-level, sudo-enabled, and web-enabled.
      </p>
      <div class="threat-overview-grid">
        <div class="threat-row">
          <span>Malicious MCP Servers</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Prompt Injection</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Misleading MCP Server Usage</span>
          <span class="tag tag-high">High</span>
        </div>
        <div class="threat-row">
          <span>Unauthorized Sudo Requests via MCP</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Sudo Capability Exploitation</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Bloated Context</span>
          <span class="tag tag-critical">Critical</span>
        </div>
      </div>
      <a href="/research" class="btn btn-outline" style="margin-top: var(--space-xl);">
        Full research &rarr;
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <span class="section-label">Get started</span>
      <h2 class="section-title">Download JARVIS OS</h2>
      <p style="margin: 0 auto var(--space-xl);">
        Grab the latest ISO, verify the checksum, and boot into an AI-native research environment.
      </p>
      <div class="hero-actions" style="justify-content: center;">
        <a href="/download" class="btn btn-primary">Download ISO</a>
        <a href="/docs" class="btn btn-outline">Read the Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-4xl) 0;
    min-height: 72vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    max-width: 760px;
    animation: fade-up 0.7s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  .hero-logo {
    width: min(380px, 100%);
    height: auto;
    margin-bottom: var(--space-xl);
    border-radius: 6px;
    opacity: 0.92;
  }

  .hero h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: 1.08rem;
    margin-bottom: var(--space-xl);
    max-width: 600px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .hero-meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.78rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    align-items: center;
  }

  /* Finding banner */
  .finding-banner {
    padding: var(--space-2xl);
    border-radius: 6px;
    background: var(--bg-card);
    border-left: 3px solid var(--red);
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
  }

  .finding-banner h2 {
    margin: var(--space-md) 0 var(--space-md);
  }

  .finding-banner p {
    max-width: 640px;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Threat overview */
  .threat-overview-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .threat-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    font-size: 0.9rem;
    transition: background var(--transition-fast), border-color var(--transition-fast), padding-left var(--transition-base);
    position: relative;
  }

  .threat-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--cyan);
    transform: scaleY(0);
    transition: transform var(--transition-base);
    transform-origin: bottom;
  }

  .threat-row:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-glow);
    padding-left: calc(var(--space-lg) + 4px);
  }

  .threat-row:hover::before {
    transform: scaleY(1);
  }

  .threat-row:first-child {
    border-radius: 6px 6px 0 0;
  }

  .threat-row:last-child {
    border-radius: 0 0 6px 6px;
  }

  /* Features asymmetric grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .features-card--lead {
    grid-column: span 2;
  }

  .features-card--wide {
    grid-column: span 2;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .features-card--lead,
    .features-card--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-3xl) 0;
    }

    .hero-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .features-card--lead,
    .features-card--wide {
      grid-column: span 1;
    }
  }
</style>
