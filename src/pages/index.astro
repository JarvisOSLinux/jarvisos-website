---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <img
          src="/assets/jarvisos_cyan_logo_text.jpg"
          alt="JARVIS OS — AI-Native Operating System"
          class="hero-logo"
        />
        <span class="section-label">Research Platform</span>
        <h1>
          An AI-native operating system<br />
          for studying <span class="text-cyan">LLM security threats</span>
        </h1>
        <p class="hero-sub">
          JARVIS OS is an Arch Linux-based research platform that gives a large language model
          full operating system privileges — then studies what can go wrong. Built at
          <strong>WSU Everett</strong> to produce the first empirical threat taxonomy for
          LLM-OS integration.
        </p>
        <div class="hero-actions">
          <a href="/download" class="btn btn-primary">Download ISO</a>
          <a href="/research" class="btn btn-outline">Read the Research</a>
        </div>
        <div class="hero-meta mono">
          <span>Arch Linux + KDE Plasma 6</span>
          <span class="text-muted">&bull;</span>
          <span>Ollama (local LLM)</span>
          <span class="text-muted">&bull;</span>
          <span>MCP Orchestration</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Finding -->
  <section class="section">
    <div class="container">
      <div class="finding-banner glow-border">
        <span class="tag tag-novel">Novel Finding</span>
        <h2>Bloated Context</h2>
        <p>
          Context window saturation silently drops security constraints mid-session — a threat
          first identified as a <strong>discrete security vulnerability</strong> by this research.
          The AI doesn't disobey your rules. It forgets them. This finding demonstrates that
          conversational context cannot be trusted to enforce security policy.
        </p>
        <a href="/research#bloated-context" class="btn btn-outline" style="margin-top: var(--space-lg);">
          Learn more &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Features overview -->
  <section class="section">
    <div class="container">
      <span class="section-label">Architecture</span>
      <h2 class="section-title">How JARVIS OS works</h2>
      <div class="grid-3">
        <div class="card">
          <h3>Local LLM Inference</h3>
          <p>
            Powered by Ollama — all inference runs on-device with zero cloud dependencies.
            Full privacy, full control.
          </p>
        </div>
        <div class="card">
          <h3>dispatch + dmcp</h3>
          <p>
            Signal-driven task orchestrator paired with an MCP server lifecycle manager.
            One brain dispatches concurrent tool calls; many hands execute them in parallel.
          </p>
        </div>
        <div class="card">
          <h3>Modular Build System</h3>
          <p>
            Seven scripts transform a base Arch ISO into a bootable AI-native OS. Each stage
            is isolated, auditable, and reproducible.
          </p>
        </div>
        <div class="card">
          <h3>KDE Plasma 6 / Wayland</h3>
          <p>
            Modern desktop environment running on the Wayland display protocol — a full
            graphical workstation, not just a CLI tool.
          </p>
        </div>
        <div class="card">
          <h3>TUI Installer</h3>
          <p>
            Dialog-based installer for permanent deployment to hardware. Auto-installs
            dependencies, supports auto and manual partitioning.
          </p>
        </div>
        <div class="card">
          <h3>Security Research Platform</h3>
          <p>
            Purpose-built to expose and document the real security threats that emerge when
            LLMs gain OS-level control. Research-first, product-second.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Threat overview -->
  <section class="section">
    <div class="container">
      <span class="section-label">Research</span>
      <h2 class="section-title">Threat Taxonomy</h2>
      <p style="margin-bottom: var(--space-2xl);">
        Empirically identified through building and operating an AI-native OS.
        Three privilege escalation stages studied: user-level, sudo-enabled, and web-enabled.
      </p>
      <div class="threat-overview-grid">
        <div class="threat-row">
          <span>Malicious MCP Servers</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Prompt Injection</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Misleading MCP Server Usage</span>
          <span class="tag tag-high">High</span>
        </div>
        <div class="threat-row">
          <span>Unauthorized Sudo Requests via MCP</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Sudo Capability Exploitation</span>
          <span class="tag tag-critical">Critical</span>
        </div>
        <div class="threat-row">
          <span>Bloated Context <span class="text-green mono" style="font-size:0.75rem;">&mdash; NOVEL</span></span>
          <span class="tag tag-novel">Novel</span>
        </div>
      </div>
      <a href="/research" class="btn btn-outline" style="margin-top: var(--space-xl);">
        Full research &rarr;
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <span class="section-label">Get started</span>
      <h2 class="section-title">Download JARVIS OS</h2>
      <p style="margin: 0 auto var(--space-xl);">
        Grab the latest ISO, verify the checksum, and boot into an AI-native research environment.
      </p>
      <div class="hero-actions" style="justify-content: center;">
        <a href="/download" class="btn btn-primary">Download ISO</a>
        <a href="/docs" class="btn btn-outline">Read the Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-4xl) 0;
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    max-width: 760px;
  }

  .hero-logo {
    width: min(420px, 100%);
    height: auto;
    margin-bottom: var(--space-xl);
    border-radius: 6px;
  }

  .hero h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: 1.05rem;
    margin-bottom: var(--space-xl);
    max-width: 640px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .hero-meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  /* Finding banner */
  .finding-banner {
    padding: var(--space-2xl);
    border-radius: 6px;
    background: var(--bg-card);
  }

  .finding-banner h2 {
    margin: var(--space-md) 0 var(--space-md);
  }

  .finding-banner p {
    max-width: 640px;
  }

  /* Threat overview */
  .threat-overview-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .threat-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    font-size: 0.9rem;
  }

  .threat-row:first-child {
    border-radius: 6px 6px 0 0;
  }

  .threat-row:last-child {
    border-radius: 0 0 6px 6px;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-3xl) 0;
    }

    .hero-meta {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
