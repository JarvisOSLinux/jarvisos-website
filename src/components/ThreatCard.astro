---
interface Props {
  title: string;
  severity: "critical" | "high" | "medium" | "novel";
  description: string;
  mitigation: string;
}

const { title, severity, description, mitigation } = Astro.props;
---

<div class="card threat-card">
  <div class="threat-header">
    <span class:list={["tag", `tag-${severity}`]}>{severity}</span>
  </div>
  <h3 class="threat-title">{title}</h3>
  <p class="threat-desc">{description}</p>
  <div class="threat-mitigation">
    <span class="mitigation-label mono">Mitigation</span>
    <p class="mitigation-text">{mitigation}</p>
  </div>
</div>

<style>
  .threat-header {
    display: flex;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .threat-title {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .threat-desc {
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .threat-mitigation {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }

  .mitigation-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .mitigation-text {
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--text-muted);
  }
</style>
