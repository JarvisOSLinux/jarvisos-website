---
interface Props {
  title: string;
  severity: "critical" | "high" | "medium" | "novel";
  description: string;
  mitigation: string;
  index?: number;
}

const { title, severity, description, mitigation, index } = Astro.props;
const num = index !== undefined ? String(index + 1).padStart(2, "0") : undefined;
---

<div class="card threat-card">
  {num && <span class="threat-num mono" aria-hidden="true">{num}</span>}
  <div class="threat-header">
    <span class:list={["tag", `tag-${severity}`]}>{severity}</span>
  </div>
  <h3 class="threat-title">{title}</h3>
  <p class="threat-desc">{description}</p>
  <div class="threat-mitigation">
    <span class="mitigation-label mono">Mitigation</span>
    <p class="mitigation-text">{mitigation}</p>
  </div>
</div>

<style>
  .threat-card {
    position: relative;
  }

  .threat-card::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--cyan);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform var(--transition-base);
    border-radius: 2px 0 0 2px;
  }

  .threat-card:hover::after {
    transform: scaleY(1);
  }

  .threat-num {
    display: block;
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    margin-bottom: var(--space-sm);
    line-height: 1;
  }

  .threat-header {
    display: flex;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .threat-title {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .threat-desc {
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .threat-mitigation {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-subtle);
    background: #00e67606;
    padding: var(--space-md);
    border-radius: 0 0 4px 4px;
    margin-left: calc(-1 * var(--space-xl));
    margin-right: calc(-1 * var(--space-xl));
    margin-bottom: calc(-1 * var(--space-xl));
  }

  .mitigation-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .mitigation-text {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--text-muted);
  }
</style>
