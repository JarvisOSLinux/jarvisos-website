---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/research", label: "Research" },
  { href: "/subsystems", label: "Subsystems" },
  { href: "/download", label: "Download" },
  { href: "/docs", label: "Docs" },
  { href: "/contributors", label: "Contributors" },
];
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <img src="/assets/jarvios_cyan_logo.png" alt="JARVIS OS" class="nav-logo-img" />
      <span class="logo-text">JARVIS OS</span>
    </a>

    <button class="nav-toggle" aria-label="Toggle menu" id="nav-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links" id="nav-links">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["nav-link", { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://github.com/JarvisOSLinux"
          class="nav-link nav-link-gh"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub &nearr;
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    background: #07090fdd;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
    transition: border-color var(--transition-base), background var(--transition-slow);
  }

  .nav.scrolled {
    background: #07090ff5;
    border-bottom-color: var(--border-glow);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.08em;
  }

  .nav-logo:hover {
    color: var(--text-primary);
  }

  .nav-logo-img {
    height: 32px;
    width: auto;
  }

  .logo-text {
    color: var(--cyan);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: var(--space-xs);
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    padding: 0.5em 0.9em;
    border-radius: 4px;
    transition: color var(--transition-fast), background var(--transition-fast);
    text-transform: lowercase;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 0.9em;
    right: 0.9em;
    height: 1px;
    background: var(--cyan);
    transform: scaleX(0);
    transition: transform var(--transition-base);
    transform-origin: center;
  }

  .nav-link:hover {
    color: var(--cyan);
    background: #00c8ff08;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--cyan);
    background: #00c8ff0a;
    border: 1px solid var(--border-glow);
  }

  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-link-gh {
    color: var(--text-muted);
  }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      padding: var(--space-md) var(--space-lg);
      gap: 0;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.75em 0.5em;
      border-radius: 0;
      border-bottom: 1px solid var(--border-subtle);
      width: 100%;
    }

    .nav-link::after {
      display: none;
    }

    .nav-link.active {
      border: none;
      border-bottom: 1px solid var(--border-subtle);
      background: #00c8ff08;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const links = document.getElementById("nav-links");
  const nav = document.querySelector(".nav");

  toggle?.addEventListener("click", () => {
    links?.classList.toggle("open");
  });

  // Scroll-aware nav border
  const onScroll = () => {
    if (window.scrollY > 60) {
      nav?.classList.add("scrolled");
    } else {
      nav?.classList.remove("scrolled");
    }
  };

  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
